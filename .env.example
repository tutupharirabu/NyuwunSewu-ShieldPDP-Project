# =============================================================================
# NyuwunSewu / ShieldPDP - Environment Configuration
# =============================================================================
#
# ⚠️ SECURITY WARNING — JANGAN PERNAH commit .env ke git!
# ⚠️ JANGAN pakai default value di production!
#
# 📋 Generate secrets dengan OpenSSL:
#   openssl rand -hex 32   # → SECRET_KEY, AGENT_SECRET, PHANTOM_WEBHOOK_SECRET
#   openssl rand -hex 16   # → password salt (optional)
#
#  Cek apakah secret sudah aman (minimal 32 chars hex = 128 bit):
#   echo -n "your-secret" | wc -c
#
# =============================================================================

# ─── Application ────────────────────────────────────────────────────────────
APP_NAME=NyuwunSewu
ENVIRONMENT=local
DEBUG=false

# ─── Security (WAJIB diganti di production!) ───────────────────────────────
# Generate dengan: openssl rand -hex 32
SECRET_KEY=replace-with-a-long-random-secret

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nyuwunsewu:nyuwunsewu@localhost:5432/nyuwunsewu
REDIS_URL=redis://localhost:6379/0

# ─── Background Tasks ──────────────────────────────────────────────────────
USE_CELERY=false

# ─── Bootstrap Admin (first-time setup) ─────────────────────────────────────
# ️ Ganti password default sebelum deploy production!
# ⚠️ Password akan di-hash dengan PBKDF2 390.000 iterasi
BOOTSTRAP_ADMIN_EMAIL=admin@nyuwunsewu.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ORGANIZATION_NAME=Default Organization

# ─── Scanner Configuration ─────────────────────────────────────────────────
ALLOW_PRIVATE_TARGETS=false
MAX_CRAWL_DEPTH=5
MAX_CRAWL_PAGES=5000
MAX_REQUESTS_PER_SECOND=5
REQUEST_TIMEOUT_SECONDS=10

# ─── Agent Hermes / Phantom Integration ────────────────────────────────────
# Shared secret untuk agent authentication di endpoint /findings/ingest
# Generate dengan: openssl rand -hex 32
PHANTOM_AGENT_SECRET=replace-with-a-long-random-secret

# Signing secret untuk verifikasi signature webhook dari ShieldPDP
# Generate dengan: openssl rand -hex 32
PHANTOM_WEBHOOK_SECRET=replace-with-a-long-random-secret

# Port untuk Phantom webhook receiver
PHANTOM_WEBHOOK_PORT=8080

# URL backend ShieldPDP (tanpa trailing slash)
NYUWUNSEWU_URL=http://127.0.0.1:8000

# ─── Agent Receiver Authentication ─────────────────────────────────────────
# Password untuk login receiver ke backend sebagai admin
# HARUS sama dengan BOOTSTRAP_ADMIN_PASSWORD di backend
ADMIN_PASSWORD=ChangeMe123!
ADMIN_EMAIL=admin@nyuwunsewu.local

# ─── Telegram Notifications (optional) ─────────────────────────────────────
# Dapatkan bot token dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
